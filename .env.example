# These are read from process.env. The app does NOT auto-load .env — export them in your shell (e.g. 'set -a; . ./.env; set +a') or use a tool like dotenv-cli.

# ── Server ───────────────────────────────────────────────────────────────
OCTORYN_SCOUT_HOST=0.0.0.0
OCTORYN_SCOUT_PORT=8787
OCTORYN_SCOUT_USER_AGENT=OctorynScout/0.1 (+https://octoryn.com)
OCTORYN_SCOUT_DATA_DIR=.octoryn-scout

# ── Fetch / cache / rate limit ───────────────────────────────────────────
OCTORYN_SCOUT_CACHE_TTL_SECONDS=900
OCTORYN_SCOUT_DEFAULT_TIMEOUT_MS=20000
OCTORYN_SCOUT_DOMAIN_RATE_LIMIT_MS=1000
OCTORYN_SCOUT_BROWSER_MAX_PAGES=4
OCTORYN_SCOUT_BROWSER_IDLE_MS=30000
# fetchProvider: pluggable static-fetch backend seam (only "local" today)
OCTORYN_SCOUT_FETCH_PROVIDER=local

# ── Anti-bot: stealth / proxies / challenges / CAPTCHA ───────────────────
# stealth: true enables hand-rolled anti-detection on browser renders
OCTORYN_SCOUT_STEALTH=false
# extraHeaders: JSON object of custom headers injected on fetch + render
OCTORYN_SCOUT_EXTRA_HEADERS=
# proxyUrls: comma-separated proxy list, round-robin rotated
OCTORYN_SCOUT_PROXY_URLS=
# challengeMaxWaitMs: how long to wait out a JS interstitial (Cloudflare etc.)
OCTORYN_SCOUT_CHALLENGE_MAX_WAIT_MS=15000
# captchaProvider: CAPTCHA solver seam ("none" = NoopCaptchaSolver placeholder)
OCTORYN_SCOUT_CAPTCHA_PROVIDER=none
OCTORYN_SCOUT_CAPTCHA_API_KEY=

# ── Security: SSRF guard + content limits ────────────────────────────────
# allowPrivateHosts MUST be true for localhost dev/tests (the guard blocks
# private/loopback/metadata IPs by default).
OCTORYN_SCOUT_ALLOW_PRIVATE_HOSTS=false
OCTORYN_SCOUT_HOST_ALLOWLIST=
OCTORYN_SCOUT_HOST_BLOCKLIST=
OCTORYN_SCOUT_MAX_CONTENT_BYTES=10485760
OCTORYN_SCOUT_ALLOWED_CONTENT_TYPES=html,pdf,xml,text,json

# ── Crawl ────────────────────────────────────────────────────────────────
OCTORYN_SCOUT_CRAWL_MAX_DEPTH=2
OCTORYN_SCOUT_CRAWL_MAX_PAGES=50
OCTORYN_SCOUT_CRAWL_CONCURRENCY=3
OCTORYN_SCOUT_CRAWL_CHECKPOINT_EVERY=10
# mapMaxUrls: cap on URLs returned by /map fast discovery
OCTORYN_SCOUT_MAP_MAX_URLS=5000

# ── Knowledge: chunking + embeddings ─────────────────────────────────────
OCTORYN_SCOUT_CHUNK_MAX_TOKENS=800
OCTORYN_SCOUT_CHUNK_OVERLAP_TOKENS=100
# embeddingProvider: stub | voyage | openai (stub = deterministic, offline)
OCTORYN_SCOUT_EMBEDDING_PROVIDER=stub
OCTORYN_SCOUT_EMBEDDING_MODEL=
VOYAGE_API_KEY=
OPENAI_API_KEY=
# vectorDim: override embedding/vector-store dimension (unset = provider default)
OCTORYN_SCOUT_VECTOR_DIM=

# ── Knowledge: retrieval + reranking ─────────────────────────────────────
# retrievalMode: vector | lexical | hybrid (hybrid = RRF fusion, default)
OCTORYN_SCOUT_RETRIEVAL_MODE=hybrid
# rerankProvider: none | heuristic | cohere | voyage (heuristic = offline default)
OCTORYN_SCOUT_RERANK_PROVIDER=heuristic
OCTORYN_SCOUT_RERANK_MODEL=
# cohereApiKey: required when rerankProvider=cohere
COHERE_API_KEY=

# ── Knowledge: LLM structured extraction ─────────────────────────────────
# extractionProvider: none | anthropic | openai (none = extraction disabled)
OCTORYN_SCOUT_EXTRACTION_PROVIDER=none
OCTORYN_SCOUT_EXTRACTION_MODEL=
# anthropicApiKey: required when extractionProvider=anthropic
ANTHROPIC_API_KEY=

# ── Governance ───────────────────────────────────────────────────────────
# approvalMode: off | flag | enforce
OCTORYN_SCOUT_APPROVAL_MODE=flag
OCTORYN_SCOUT_POLICY_FILE=

# ── Access control (API key) ─────────────────────────────────────────────
# authMode: off | write | all. With keys set, write protects mutating
# requests + /governance, /audit, /admin.
OCTORYN_SCOUT_AUTH_MODE=off
OCTORYN_SCOUT_API_KEYS=

# ── Retention (0 = keep everything) ──────────────────────────────────────
OCTORYN_SCOUT_SNAPSHOT_RETENTION_VERSIONS=0
OCTORYN_SCOUT_SNAPSHOT_RETENTION_DAYS=0
OCTORYN_SCOUT_AUDIT_RETENTION_DAYS=0

# ── Eventing: webhooks ───────────────────────────────────────────────────
OCTORYN_SCOUT_WEBHOOK_URLS=
OCTORYN_SCOUT_WEBHOOK_SECRET=
OCTORYN_SCOUT_WEBHOOK_EVENTS=*
OCTORYN_SCOUT_WEBHOOK_TIMEOUT_MS=5000
OCTORYN_SCOUT_WEBHOOK_MAX_ATTEMPTS=3

# ── Scheduled staleness refresh ──────────────────────────────────────────
OCTORYN_SCOUT_SCHEDULE_ENABLED=false
OCTORYN_SCOUT_REFRESH_INTERVAL_MS=3600000
OCTORYN_SCOUT_STALENESS_MAX_AGE_DAYS=7
OCTORYN_SCOUT_REFRESH_LIMIT=50
# schedulerLockTtlMs: TTL of the Redis lock guarding the staleness sweep
OCTORYN_SCOUT_SCHEDULER_LOCK_TTL_MS=300000

# ── Storage backend ───────────────────────────────────────────────────────
# Which store powers snapshots/vectors/audit/approvals/crawl-jobs.
#   auto   (default) — SQLite when no DATABASE_URL is set; Postgres when it is
#   sqlite — force the embedded SQLite store
#   file   — plain-JSON files under the data dir (legacy fallback)
# SQLite is the default single-file store (octopus-scout.db under the data dir)
# and needs no external services — clone and run.
OCTORYN_SCOUT_STORAGE_BACKEND=auto

# ── Optional backing services ────────────────────────────────────────────
# When DATABASE_URL is set, snapshots/vectors/audit/approvals/crawl-jobs use
# Postgres + pgvector (good for large corpora / multi-instance); the rate
# limiter + queues use Redis when REDIS_URL is set. Omit both for the
# zero-infra embedded SQLite default.
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgres://octoryn:octoryn@localhost:5432/octopus_scout
